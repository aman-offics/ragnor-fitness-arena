<script>
    function calculateBMI() {

        var height = document.getElementById("height").value;
        var weight = document.getElementById("weight").value;

        if (height === "" || weight === "") {
            alert("Please enter height and weight");
            return;
        }

        // Convert cm to meter
        height = height / 100;

        // BMI Formula
        var bmi = weight / (height * height);

        bmi = bmi.toFixed(2);

        var status = "";
        var color = "";

        if (bmi < 18.5) {
            status = "Underweight";
            color = "#ffc107";
        }
        else if (bmi >= 18.5 && bmi < 25) {
            status = "Healthy";
            color = "#28a745";
        }
        else if (bmi >= 25 && bmi < 30) {
            status = "Overweight";
            color = "#fd7e14";
        }
        else {
            status = "Obese";
            color = "#dc3545";
        }

        var resultDiv = document.getElementById("bmiResult");

        resultDiv.style.display = "block";
        resultDiv.style.borderLeft = "4px solid " + color;

        resultDiv.innerHTML =
            "<h4 style='color:white;'>Your BMI Result</h4>" +
            "<p style='margin:0;'>BMI: <strong>" + bmi + "</strong></p>" +
            "<p style='margin:0;'>Status: <strong style='color:" + color + "'>" + status + "</strong></p>";
    }
</script> *@



<!-- Breadcrumb Section Begin -->
<section class="breadcrumb-section set-bg" data-setbg="/User/img/breadcrumb-bg.jpg">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb-text">
                    <h2>BMI Calculator</h2>
                    <div class="bt-option">
                        <a href="./index.html">Home</a>
                        <span>BMI Calculator</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb Section End -->
<!-- BMI Calculator Section Begin -->
<section class="bmi-calculator-section spad">
    <div class="container">
        <div class="row">

            <!-- BMI Chart -->
            <div class="col-lg-6">
                <div class="section-title chart-title">
                    <span>Check Your Body</span>
                    <h2>BMI CALCULATOR CHART</h2>
                </div>

                <div class="chart-table">
                    <table>
                        <thead>
                            <tr>
                                <th>BMI</th>
                                <th>WEIGHT STATUS</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <td class="point">Below 18.5</td>
                                <td>Underweight</td>
                            </tr>

                            <tr>
                                <td class="point">18.5 - 24.9</td>
                                <td>Healthy</td>
                            </tr>

                            <tr>
                                <td class="point">25.0 - 29.9</td>
                                <td>Overweight</td>
                            </tr>

                            <tr>
                                <td class="point">30.0 and Above</td>
                                <td>Obese</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- BMI Form -->
            <div class="col-lg-6">

                <div class="section-title chart-calculate-title">
                    <span>Check Your Body</span>
                    <h2>CALCULATE YOUR BMI</h2>
                </div>

                <div class="chart-calculate-form">

                    <p>
                        Check your body composition and understand your fitness level
                        with our BMI calculator. Take the first step towards a healthier lifestyle.
                    </p>

                    <form onsubmit="return false;">

                        <div class="row">

                            <div class="col-sm-6">
                                <input type="number"
                                       id="height"
                                       placeholder="Height / cm">
                            </div>

                            <div class="col-sm-6">
                                <input type="number"
                                       id="weight"
                                       placeholder="Weight / kg">
                            </div>

                            <div class="col-lg-12">
                                <button type="button" id="bmiBtn">
                                    CALCULATE
                                </button>
                            </div>

                            <!-- BMI RESULT -->
                            <div id="bmiResult"
                                 style="
                                 display:none;
                                 margin-top:20px;
                                 background:#111;
                                 color:white;
                                 padding:20px;
                                 border-left:4px solid #f36100;
                                 border-radius:5px;">
                            </div>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</section>
<!-- BMI Calculator Section End -->
<!-- BMI SCRIPT -->
<script>

    document.getElementById("bmiBtn").addEventListener("click", function () {

        var height = document.getElementById("height").value;
        var weight = document.getElementById("weight").value;

        if (height == "" || weight == "") {
            alert("Please enter height and weight");
            return;
        }

        // Height in cm → meter
        height = height / 100;

        var bmi = weight / (height * height);

        bmi = bmi.toFixed(2);

        var status = "";
        var color = "";

        if (bmi < 18.5) {
            status = "Underweight";
            color = "#ffc107";
        }
        else if (bmi < 25) {
            status = "Healthy";
            color = "#28a745";
        }
        else if (bmi < 30) {
            status = "Overweight";
            color = "#fd7e14";
        }
        else {
            status = "Obese";
            color = "#dc3545";
        }

        var resultDiv = document.getElementById("bmiResult");

        resultDiv.style.display = "block";

        resultDiv.innerHTML =
            "<h4 style='color:white;'>Your BMI Result</h4>" +
            "<p>BMI: <strong>" + bmi + "</strong></p>" +
            "<p>Status: <strong style='color:" + color + "'>" + status + "</strong></p>";

    });
</script>