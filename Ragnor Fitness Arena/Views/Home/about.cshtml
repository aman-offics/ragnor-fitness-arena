@{
    ViewData["Title"] = "About";
}

<!-- Breadcrumb Section -->
<section class="breadcrumb-section set-bg" data-setbg="/User/img/breadcrumb-bg.jpg">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb-text">
                    <h2>About us</h2>
                    <div class="bt-option">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                        <span>About</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Chose Us Section -->
<section class="choseus-section spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title">
                    <span>Why choose us?</span>
                    <h2>PUSH YOUR LIMITS FORWARD</h2>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 col-sm-6">
                <div class="cs-item">
                    <span class="flaticon-034-stationary-bike"></span>
                    <h4>Modern equipment</h4>
                    <p>  Train with high-quality, modern gym equipment designed for safety and performance.</p>
                </div>
            </div>

            <div class="col-lg-3 col-sm-6">
                <div class="cs-item">
                    <span class="flaticon-033-juice"></span>
                    <h4>Healthy nutrition plan</h4>
                    <p>
                        Train with high-quality, modern gym equipment designed for safety and performance.
                    </p>
                </div>
            </div>

            <div class="col-lg-3 col-sm-6">
                <div class="cs-item">
                    <span class="flaticon-002-dumbell"></span>
                    <h4>Professional training plan</h4>
                    <p> Expert trainers provide structured workout plans tailored to your needs.</p>
                </div>
            </div>

            <div class="col-lg-3 col-sm-6">
                <div class="cs-item">
                    <span class="flaticon-014-heart-beat"></span>
                    <h4>Unique to your needs</h4>
                    <p> Expert trainers provide structured workout plans tailored to your needs.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Us Section -->
<section class="aboutus-section">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-6 p-0">
                <div class="about-video set-bg" data-setbg="/User/img/about-us.jpg">
                    <a href="https://www.youtube.com/watch?v=EzKkl64rRbM"
                       class="play-btn video-popup">
                        <i class="fa fa-caret-right"></i>
                    </a>
                </div>
            </div>

            <div class="col-lg-6 p-0">
                <div class="about-text">
                    <div class="section-title">
                        <span>About Us</span>
                        <h2>What we have done</h2>
                    </div>
                    <div class="at-desc">
                        <p>
                            At Ragnar Fitness Arena, we believe fitness is not just about building muscles—it's about building a stronger, healthier lifestyle.

                            Our mission is to help individuals transform their lives through expert training, personalized workout plans, and a motivating environment. Whether you're a beginner or an experienced athlete, we provide the right guidance to help you achieve your goals.

                            With certified trainers, modern equipment, and structured programs like weight loss, strength training, yoga, and boxing, we ensure every member gets the best fitness experience.

                            Join us and take the first step towards a stronger version of yourself.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


