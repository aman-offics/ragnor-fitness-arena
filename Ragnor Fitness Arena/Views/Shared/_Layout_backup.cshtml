                                    <li><a asp-controller="Home" asp-action="about">About Us</a></li>
                                    <li><a asp-controller="Home" asp-action="ClassTimetable">Class Timetable</a></li>
                                    <li><a asp-controller="Home" asp-action="bmicalculator">BMI Calculator</a></li>
                                    <li><a asp-controller="Home" asp-action="Team">Team</a></li>
                                    <li><a asp-controller="Home" asp-action="Gallery">Gallery</a></li>
                                    <li><a asp-controller="Home" asp-action="blog">Blog</a></li>
                                    <li><a asp-controller="Home" asp-action="Error404">404</a></li>
                                </ul>
                            </li>

