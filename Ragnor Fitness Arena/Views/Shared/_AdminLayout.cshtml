<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Muli:300,400,500,600,700,800,900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Oswald:300,400,500,600,700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- CSS FILES (IMPORTANT: ~/ use pannunga) -->
    <link rel="stylesheet" href="/User/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/User/css/font-awesome.min.css" />
    <link rel="stylesheet" href="/User/css/flaticon.css" />
    <link rel="stylesheet" href="/User/css/owl.carousel.min.css" />
    <link rel="stylesheet" href="/User/css/barfiller.css" />
    <link rel="stylesheet" href="/User/css/magnific-popup.css" />
    <link rel="stylesheet" href="/User/css/slicknav.min.css" />
    <link rel="stylesheet" href="/User/css/style.css" />

    <!-- 🔁 SAME TEMPLATE CSS -->
    @* <link rel="stylesheet" href="~/css/bootstrap.min.css" /> *@
    @* <link rel="stylesheet" href="~/css/font-awesome.min.css" /> *@
    @* <link rel="stylesheet" href="~/css/style.css" /> *@
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="Admin" asp-action="Dashboard">
                Ragnor Admin
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="adminNavbar">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Users">Users</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Plans">Plans</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="MembershipList">Memberships</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="TrialBookings">
                            Trial Bookings
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="TrainerAppointments">
                            Trainer Appointments
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class ="nav-link" asp-controller="Admin" asp-action="ContactMessages">
                            Contact Messages
                        </a>
                    </li>


                </ul>

                <a asp-controller="Home" asp-action="Index" 
   class="btn btn-outline-light btn-sm me-2">
    Go to Website
</a>

                <a asp-controller="Admin" asp-action="Logout" class="btn btn-danger btn-sm">
                    Logout
                </a>


            </div>

        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>
