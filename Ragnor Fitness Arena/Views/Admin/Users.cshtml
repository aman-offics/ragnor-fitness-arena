@{
    ViewData["Title"] = "Users";
    Layout = "_AdminLayout";
    var users = ViewBag.Users as List<string[]>;
}

<h3 class="mb-4">Users List</h3>

<a href="/Admin/AddUser" class="btn btn-primary mb-3">+ Add User</a>

<table class="table table-dark table-bordered">
    <thead>
        <tr>
            <th>#</th>
            <th>Full Name</th>
            <th>Email</th>
            <th>Joined On</th>
            <th>Action</th>

        </tr>
    </thead>
    <tbody>
        @{
            int i = 1;
            foreach (var u in users)
            {
                <tr>
                    <td>@i</td>
                    <td>@u[0]</td>
                    <td>@u[1]</td>
                    <td>@u[2]</td>
                    <td>
                        <a href="/Admin/DeleteUser?id=@u[0]"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure you want to delete this user?');">
                            Delete
                        </a>
                        <a href="/Admin/EditUser?id=@u[0]"
                           class="btn btn-warning btn-sm me-1">
                            Edit
                        </a>


                    </td>

                </tr>
                i++;
            }
        }
    </tbody>
</table>
